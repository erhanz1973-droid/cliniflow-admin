SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=
ADMIN_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=patient-files
ROBOFLOW_API_KEY=

# ── App Config ────────────────────────────────────────────────────────────────
NODE_ENV=production
APP_ENV=production

# ── Core AI ───────────────────────────────────────────────────────────────────
# Required: GPT-4o Vision for dental photo analysis
OPENAI_API_KEY=

# Optional: Replicate GFPGAN face/dental enhancement
REPLICATE_API_TOKEN=

# ── Image Processing ──────────────────────────────────────────────────────────
# Max upload size for images (MB). Applies to /api/chat/upload and /api/chat/ai-analyze
IMAGE_MAX_SIZE_MB=5
# Timeout (ms) for OpenAI + Replicate calls
AI_TIMEOUT_MS=15000

# ── Storage ───────────────────────────────────────────────────────────────────
# Set UPLOAD_PROVIDER=s3 to upload AI-input images to S3 (gives Replicate a public URL)
# Leave empty to use local disk + base64 encoding
UPLOAD_PROVIDER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
S3_BUCKET_NAME=clinifly-ai-images

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to "false" to disable individual features without removing env vars
ENABLE_AI_ANALYSIS=true
ENABLE_SMILE_SIMULATION=true
ENABLE_MULTI_PHOTO_PROGRESS=true
